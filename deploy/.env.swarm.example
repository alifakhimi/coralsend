# Docker Swarm + Traefik / Dokploy
# Copy to .env.swarm and customize. Use with:
#   docker stack deploy --env-file deploy/.env.swarm -c deploy/docker-compose.swarm.yml coralsend

# Domain for Traefik routing
TRAEFIK_HOST=coralsend.example.com

# External network (dokploy-network for Dokploy)
TRAEFIK_NETWORK=dokploy-network

# HTTPS: websecure + letsencrypt
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_TLS_CERTRESOLVER=letsencrypt

# Include base app env (SERVER_PORT, WEB_PORT, etc.) from .env.local
